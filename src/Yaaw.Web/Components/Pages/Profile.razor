@page "/profile"
@attribute [Authorize]
@inject JwtAuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<div class="flex items-center justify-center min-h-screen bg-surface-950">
    <div class="w-full max-w-sm mx-4">
        <div class="bg-surface-900 border border-surface-700/50 rounded-2xl p-8 space-y-6 animate-fade-in">
            <div class="text-center space-y-2">
                <div class="w-16 h-16 mx-auto bg-accent/10 rounded-full flex items-center justify-center">
                    <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                    </svg>
                </div>
                <h1 class="text-xl font-semibold text-surface-100">Profile</h1>
            </div>

            <AuthorizeView>
                <Authorized>
                    <div class="space-y-3">
                        <div class="bg-surface-950 rounded-xl px-4 py-3">
                            <p class="text-[10px] uppercase tracking-wider text-surface-500 mb-1">Name</p>
                            <p class="text-sm text-surface-200">@context.User.Identity?.Name</p>
                        </div>
                        <div class="bg-surface-950 rounded-xl px-4 py-3">
                            <p class="text-[10px] uppercase tracking-wider text-surface-500 mb-1">Email</p>
                            <p class="text-sm text-surface-200">@context.User.FindFirst("email")?.Value</p>
                        </div>
                        <div class="bg-surface-950 rounded-xl px-4 py-3">
                            <p class="text-[10px] uppercase tracking-wider text-surface-500 mb-1">User ID</p>
                            <p class="text-xs text-surface-400 font-mono">@context.User.FindFirst("sub")?.Value</p>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>

            <div class="flex flex-col gap-2">
                <a href="/"
                   class="w-full py-2.5 rounded-xl bg-surface-800 text-surface-200 font-medium text-sm text-center
                          hover:bg-surface-700 transition-colors duration-200">
                    Back to Chat
                </a>
                <button @onclick="HandleLogout"
                        class="w-full py-2.5 rounded-xl border border-red-500/30 text-red-400 font-medium text-sm
                               hover:bg-red-500/10 transition-colors duration-200">
                    Sign out
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private async Task HandleLogout()
    {
        await AuthState.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
