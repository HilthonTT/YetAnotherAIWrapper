@page "/"
@using Yaaw.Web.Components.Chat
@inject ChatApiService Api
@inject ChatStreamService Stream
@inject MarkdownService Markdown
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="@SidebarCss">
        <div class="flex items-center justify-between p-4 border-b border-surface-800/60">
            <h1 class="text-lg font-semibold tracking-tight text-accent">Yaaw</h1>
            <button @onclick="ToggleSidebar" class="lg:hidden p-1.5 rounded-lg hover:bg-surface-800 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <div class="p-3 space-y-2">
            <button @onclick="CreateNewConversation"
                    class="w-full flex items-center gap-2.5 px-4 py-2.5 rounded-xl bg-accent/10 text-accent
                           hover:bg-accent/20 transition-all duration-200 text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                New conversation
            </button>

            <!-- Search -->
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-surface-500 pointer-events-none"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                </svg>
                <input type="text"
                       @bind="_searchText"
                       @bind:event="oninput"
                       @bind:after="OnSearchChangedAsync"
                       placeholder="Search conversations..."
                       class="w-full bg-surface-900 border border-surface-700/50 rounded-lg text-xs text-surface-200
                              placeholder-surface-500 pl-8 pr-3 py-2 focus:outline-none focus:border-accent/40
                              transition-colors duration-200" />
            </div>

            <!-- Sort -->
            <select @bind="_sortField" @bind:after="OnSortChangedAsync"
                    class="w-full bg-surface-900 border border-surface-700/50 rounded-lg text-xs text-surface-300
                px-3 py-2 focus:outline-none focus:border-accent/40 transition-colors duration-200
                appearance-none cursor-pointer">
                <option value="id desc">Newest first</option>
                <option value="id">Oldest first</option>
                <option value="name">Name A–Z</option>
                <option value="name desc">Name Z–A</option>
            </select>
        </div>

        <nav class="flex-1 overflow-y-auto px-3 pb-4 space-y-1 scrollbar-thin">
            @foreach (var convo in _conversations)
            {
                <div class="group relative">
                    @if (_renamingId == convo.Id)
                    {
                        <div class="flex items-center gap-1.5 px-2 py-1.5">
                            <input @ref="_renameInputRef"
                                   @bind="_renameText"
                                   @onkeydown="HandleRenameKeyDown"
                                   class="flex-1 bg-surface-800 border border-accent/40 rounded-md text-sm text-surface-100
                                          px-2 py-1 focus:outline-none min-w-0" />
                            <button @onclick="ConfirmRenameAsync"
                                    class="p-1 rounded-md hover:bg-green-500/20 text-green-400 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                            </button>
                            <button @onclick="CancelRename"
                                    class="p-1 rounded-md hover:bg-red-500/20 text-red-400 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </div>
                    }
                    else
                    {
                        <button @onclick="() => SelectConversation(convo.Id)"
                                @ondblclick="() => StartRename(convo)"
                                class="@ConversationItemCss(convo.Id)">
                            <svg class="w-4 h-4 shrink-0 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                            </svg>
                            <span class="truncate">@convo.Name</span>
                        </button>
                        <div class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-0.5
                                    opacity-0 group-hover:opacity-100 transition-all duration-150">
                            <button @onclick="() => StartRename(convo)"
                                    @onclick:stopPropagation="true"
                                    class="p-1 rounded-md hover:bg-surface-700 hover:text-surface-200 text-surface-500 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
                                </svg>
                            </button>
                            <button @onclick="() => DeleteConversation(convo.Id)"
                                    @onclick:stopPropagation="true"
                                    class="p-1 rounded-md hover:bg-red-500/20 hover:text-red-400 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            }
        </nav>
    </aside>

    @* Overlay for mobile sidebar *@
    @if (_sidebarOpen)
    {
        <div @onclick="ToggleSidebar" class="fixed inset-0 bg-black/50 z-30 lg:hidden"></div>
    }

    <!-- Main chat area -->
    <main class="flex-1 flex flex-col min-w-0">
        <!-- Top bar -->
        <header class="flex items-center gap-3 px-4 py-3 border-b border-surface-800/60 bg-surface-950/50 backdrop-blur-sm">
            <button @onclick="ToggleSidebar" class="lg:hidden p-1.5 rounded-lg hover:bg-surface-800 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
                </svg>
            </button>
            <h2 class="text-sm font-medium text-surface-300 truncate">
                @(_activeConversation?.Name ?? "Select a conversation")
            </h2>
        </header>

        <!-- Messages -->
        <div @ref="_messagesContainer" class="flex-1 overflow-y-auto scroll-smooth">
            @if (_activeConversation is null)
            {
                <EmptyState OnNewConversation="CreateNewConversation" />
            }
            else if (_messages.Count == 0)
            {
                <div class="flex items-center justify-center h-full">
                    <p class="text-surface-500 text-sm">Send a message to start the conversation.</p>
                </div>
            }
            else
            {
                <div class="max-w-3xl mx-auto px-4 py-6 space-y-6">
                    @foreach (var msg in _messages)
                    {
                        <MessageBubble Message="msg" MarkdownService="Markdown" />
                    }
                </div>
            }
        </div>

        <!-- Input area -->
        @if (_activeConversation is not null)
        {
            <div class="border-t border-surface-800/60 bg-surface-950/80 backdrop-blur-sm">
                <div class="max-w-3xl mx-auto p-4">
                    <div class="relative flex items-end gap-2 bg-surface-900 rounded-2xl border border-surface-700/50
                                  focus-within:border-accent/40 transition-colors duration-200">
                        <textarea @ref="_inputRef"
                                  @bind="_inputText"
                                  @bind:event="oninput"
                                  @onkeydown="HandleKeyDown"
                                  placeholder="Message Yaaw..."
                                  rows="1"
                                  disabled="@_isSending"
                                  class="flex-1 bg-transparent text-surface-100 placeholder-surface-500 text-sm
                                         resize-none py-3 pl-4 pr-2 max-h-40 overflow-y-auto
                                         focus:outline-none disabled:opacity-50" />
                        <button @onclick="SendMessage"
                                disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isSending)"
                                class="m-1.5 p-2 rounded-xl bg-accent text-surface-950 font-medium
                                       hover:bg-accent-dim disabled:opacity-30 disabled:cursor-not-allowed
                                       transition-all duration-200">
                            @if (_isSending)
                            {
                                <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                                </svg>
                            }
                            else
                            {
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
                                </svg>
                            }
                        </button>
                    </div>
                    <p class="text-center text-[10px] text-surface-600 mt-2">
                        Yaaw can make mistakes. Verify important information.
                    </p>
                </div>
            </div>
        }
    </main>
</div>

@code {
    private List<ConversationDto> _conversations = [];
    private ConversationDto? _activeConversation;
    private List<ChatMessage> _messages = [];
    private string _inputText = "";
    private bool _isSending;
    private bool _sidebarOpen;
    private CancellationTokenSource? _streamCts;
    private ElementReference _messagesContainer;
    private ElementReference _inputRef;
    private bool _shouldScrollToBottom;

    // Search & sort
    private string _searchText = "";
    private string _sortField = "id desc";
    private CancellationTokenSource? _searchDebounce;

    // Rename
    private Guid? _renamingId;
    private string _renameText = "";
    private ElementReference _renameInputRef;

    protected override async Task OnInitializedAsync()
    {
        await LoadConversationsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScrollToBottom)
        {
            _shouldScrollToBottom = false;
            await ScrollToBottomAsync();
        }

        if (_renamingId is not null)
        {
            try 
            { 
                await _renameInputRef.FocusAsync();
            } 
            catch
            {
            }
        }
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", _messagesContainer);
        }
        catch { }
    }

    private async Task LoadConversationsAsync()
    {
        try
        {
            string? search = string.IsNullOrWhiteSpace(_searchText) ? null : _searchText.Trim();
            _conversations = await Api.GetConversationsAsync(search: search, sort: _sortField);
        }
        catch
        {
            _conversations = [];
        }
    }

    private async Task OnSearchChangedAsync()
    {
        _searchDebounce?.Cancel();
        _searchDebounce = new CancellationTokenSource();

        try
        {
            await Task.Delay(300, _searchDebounce.Token);
            await LoadConversationsAsync();
            StateHasChanged();
        }
        catch (OperationCanceledException) { }
    }

    private async Task OnSortChangedAsync()
    {
        await LoadConversationsAsync();
        StateHasChanged();
    }

    private async Task SelectConversation(Guid id)
    {
        if (_renamingId is not null)
        {
            return;
        }

        CancelActiveStream();

        _activeConversation = _conversations.FirstOrDefault(c => c.Id == id);
        _sidebarOpen = false;

        if (_activeConversation is not null)
        {
            var full = await Api.GetConversationAsync(id);
            if (full is not null)
            {
                _activeConversation = full;
                _messages = full.Messages
                    .Select(m => new ChatMessage
                    {
                        Id = m.Id,
                        Role = m.Role,
                        Text = m.Text,
                    })
                    .ToList();
            }

            _ = Stream.EnsureConnectedAsync();
        }

        _shouldScrollToBottom = true;
        StateHasChanged();
    }

    private async Task CreateNewConversation()
    {
        var name = $"Chat {DateTime.Now:MMM d, h:mm tt}";
        var convo = await Api.CreateConversationAsync(name);

        if (convo is not null)
        {
            _conversations.Insert(0, convo);
            await SelectConversation(convo.Id);
        }
    }

    private async Task DeleteConversation(Guid id)
    {
        try
        {
            await Api.DeleteConversationAsync(id);
            _conversations.RemoveAll(c => c.Id == id);

            if (_activeConversation?.Id == id)
            {
                _activeConversation = null;
                _messages.Clear();
                CancelActiveStream();
            }

            if (_renamingId == id)
            {
                CancelRename();
            }

            StateHasChanged();
        }
        catch { }
    }

    private void StartRename(ConversationDto convo)
    {
        _renamingId = convo.Id;
        _renameText = convo.Name;
    }

    private void CancelRename()
    {
        _renamingId = null;
        _renameText = "";
    }

    private async Task ConfirmRenameAsync()
    {
        if (_renamingId is null || string.IsNullOrWhiteSpace(_renameText))
        {
            CancelRename();
            return;
        }

        try
        {
            var updated = await Api.RenameConversationAsync(_renamingId.Value, _renameText.Trim());

            if (updated is not null)
            {
                int index = _conversations.FindIndex(c => c.Id == _renamingId.Value);
                if (index >= 0)
                {
                    _conversations[index] = updated;
                }

                if (_activeConversation?.Id == _renamingId.Value)
                {
                    _activeConversation = updated;
                }
            }
        }
        catch { }

        CancelRename();
        StateHasChanged();
    }

    private async Task HandleRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ConfirmRenameAsync();
        }
        else if (e.Key == "Escape")
        {
            CancelRename();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_inputText) || _activeConversation is null || _isSending)
        {
            return;
        }

        var text = _inputText.Trim();
        _inputText = "";
        _isSending = true;

        var userMsg = new ChatMessage
        {
            Id = Guid.CreateVersion7(),
            Role = "user",
            Text = text,
        };
        _messages.Add(userMsg);

        var assistantMsg = new ChatMessage
        {
            Id = Guid.Empty,
            Role = "assistant",
            Text = "",
            IsStreaming = true,
            IsPlaceholder = true,
        };
        _messages.Add(assistantMsg);

        _shouldScrollToBottom = true;
        StateHasChanged();

        try
        {
            await Stream.EnsureConnectedAsync();

            _streamCts = new CancellationTokenSource();
            Guid? lastMessageId = _activeConversation.Messages.LastOrDefault()?.Id;

            _ = Task.Run(async () =>
            {
                try
                {
                    await foreach (var fragment in Stream.StreamAsync(
                        _activeConversation.Id, lastMessageId, _streamCts.Token))
                    {
                        await InvokeAsync(() =>
                        {
                            ProcessFragment(fragment, assistantMsg);
                            StateHasChanged();
                        });
                    }
                }
                catch (OperationCanceledException) { }
                catch (Exception)
                {
                    await InvokeAsync(() =>
                    {
                        assistantMsg.Text = assistantMsg.Text.Length > 0
                            ? assistantMsg.Text
                            : "Connection lost. Please try again.";
                        assistantMsg.IsStreaming = false;
                        assistantMsg.IsPlaceholder = false;
                        _isSending = false;
                        StateHasChanged();
                    });
                }
            });

            await Task.Delay(100);

            await Api.SendPromptAsync(_activeConversation.Id, text);
        }
        catch
        {
            assistantMsg.Text = "Failed to send message. Please try again.";
            assistantMsg.IsStreaming = false;
            assistantMsg.IsPlaceholder = false;
            _isSending = false;
            StateHasChanged();
        }
    }

    private void ProcessFragment(ClientMessageFragmentDto fragment, ChatMessage assistantMsg)
    {
        if (fragment.Sender == "user")
        {
            var existing = _messages.FirstOrDefault(m => m.Role == "user" && m.Text == fragment.Text);
            if (existing is not null)
            {
                existing.Id = fragment.Id;
            }
            return;
        }

        if (assistantMsg.Id == Guid.Empty)
        {
            assistantMsg.Id = fragment.Id;
        }

        if (fragment.IsFinal)
        {
            assistantMsg.IsStreaming = false;
            assistantMsg.IsPlaceholder = false;
            _isSending = false;
            return;
        }

        if (assistantMsg.IsPlaceholder && fragment.Text != "Generating reply...")
        {
            assistantMsg.IsPlaceholder = false;
            assistantMsg.Text = fragment.Text;
        }
        else if (!assistantMsg.IsPlaceholder)
        {
            assistantMsg.Text += fragment.Text;
        }

        _shouldScrollToBottom = true;
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private void CancelActiveStream()
    {
        _streamCts?.Cancel();
        _streamCts?.Dispose();
        _streamCts = null;
    }

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;

    private string SidebarCss =>
        $"flex flex-col w-72 bg-surface-950 border-r border-surface-800/60 " +
        $"fixed inset-y-0 left-0 z-40 transition-transform duration-300 lg:relative lg:translate-x-0 " +
        (_sidebarOpen ? "translate-x-0" : "-translate-x-full");

    private string ConversationItemCss(Guid id) =>
        $"w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-left truncate transition-colors duration-150 " +
        (_activeConversation?.Id == id
            ? "bg-surface-800 text-surface-100"
            : "text-surface-400 hover:bg-surface-800/50 hover:text-surface-200");

    public async ValueTask DisposeAsync()
    {
        _searchDebounce?.Cancel();
        _searchDebounce?.Dispose();
        CancelActiveStream();
        await Stream.DisposeAsync();
    }
}
