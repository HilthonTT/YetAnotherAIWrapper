@namespace Yaaw.Web.Components.Chat

<div class="animate-slide-up">
    @if (Message.Role == "user")
    {
        <!-- User message — right-aligned bubble -->
        <div class="flex justify-end">
            <div class="max-w-[85%] md:max-w-[70%]">
                <div class="bg-accent/15 text-surface-100 rounded-2xl rounded-br-md px-4 py-2.5">
                    <p class="text-sm whitespace-pre-wrap leading-relaxed">@Message.Text</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Assistant message — left-aligned -->
        <div class="flex gap-3">
            <div class="w-7 h-7 rounded-lg bg-accent/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                </svg>
            </div>
            <div class="max-w-[85%] md:max-w-[75%] min-w-0">
                @if (Message.IsPlaceholder)
                {
                    <div class="flex items-center gap-1.5 py-2">
                        <div class="w-2 h-2 rounded-full bg-accent animate-pulse-dot"></div>
                        <div class="w-2 h-2 rounded-full bg-accent animate-pulse-dot" style="animation-delay: 0.2s"></div>
                        <div class="w-2 h-2 rounded-full bg-accent animate-pulse-dot" style="animation-delay: 0.4s"></div>
                    </div>
                }
                else
                {
                    <div class="prose-chat text-sm leading-relaxed text-surface-200">
                        @MarkdownService.Render(Message.Text)
                    </div>
                    @if (Message.IsStreaming)
                    {
                        <span class="inline-block w-2 h-4 bg-accent/70 animate-pulse ml-0.5 align-text-bottom rounded-sm"></span>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] 
    public ChatMessage Message { get; set; } = default!;

    [Parameter, EditorRequired] 
    public MarkdownService MarkdownService { get; set; } = default!;
}
